APP_PORT=8080
APP_BASE_URL=http://localhost:8080
RUST_LOG=info,tower_http=info
REQUEST_CACHE_TTL_SECONDS=60
HR_API_RATE_LIMIT_REQUESTS=60
HR_API_RATE_LIMIT_WINDOW_SECONDS=60
